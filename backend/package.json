{
  "name": "mood-tracker-backend",
  "version": "1.0.0",
  "description": "Backend for health tracker app",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "deploy:heroku": "git -C .. push --force heroku \"$(git -C .. subtree split --prefix backend HEAD)\":master",
    "deploy:production": "npm run deploy:heroku && heroku run \"npm run migrate\" --app mood--backend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "pg": "^8.9.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
